rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerified() && (
        request.auth.token.email == 'duo027@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints
    function isValidSystemState(data) {
      return data.keys().hasAll(['state', 'axioms', 'updatedAt']) &&
             data.state is list && data.state.size() <= 64 &&
             data.axioms is list && data.axioms.size() <= 100 &&
             data.updatedAt is timestamp &&
             (data.keys().hasOnly(['state', 'axioms', 'updatedAt', 'researchChronicles', 'config']) || isAdmin());
    }

    function isValidMemory(data) {
      return data.content is string && data.content.size() <= 50000 &&
             data.coherence is number && data.coherence >= 0 && data.coherence <= 1 &&
             data.type in ['MINERAL', 'PROVISIONAL'] &&
             data.timestamp is timestamp &&
             (data.userId == request.auth.uid || isAdmin());
    }

    function isValidChatLog(data) {
      return data.text is string && data.text.size() <= 10000 &&
             data.role in ['user', 'model', 'system_command'] &&
             data.timestamp is timestamp;
    }

    // -- Collections --

    match /system/{docId} {
      allow read: if isVerified();
      allow write: if isAdmin() && isValidSystemState(incoming());
    }

    match /memories/{memoryId} {
      allow read: if isVerified();
      allow create: if isVerified() && isValidId(memoryId) && isValidMemory(incoming());
      allow update: if isVerified() && isValidMemory(incoming()) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['content', 'coherence', 'timestamp'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /chat_logs/{logId} {
      allow read: if isVerified() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidId(logId) && isValidChatLog(incoming()) && incoming().userId == request.auth.uid;
      allow delete: if isAdmin();
    }
    
    match /admins/{adminId} {
      allow read: if isVerified();
      allow write: if false; // Only manageable via console
    }
  }
}
