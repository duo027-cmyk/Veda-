{
  "entities": {
    "SystemState": {
      "title": "SystemState",
      "description": "Global state of the VEDA AGI core.",
      "type": "object",
      "properties": {
        "state": { "type": "array", "description": "Encoded system state vector." },
        "axioms": { "type": "array", "description": "Core system axioms." },
        "researchChronicles": { "type": "array", "description": "History of strategic evolutions." },
        "config": { "type": "object", "description": "System configuration parameters." },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["state", "axioms", "updatedAt"]
    },
    "Memory": {
      "title": "Memory",
      "description": "A single knowledge fragment or epistemic anchor.",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "coherence": { "type": "number" },
        "type": { "type": "string", "enum": ["MINERAL", "PROVISIONAL"] },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "coherence", "type", "timestamp"]
    },
    "ChatLog": {
      "title": "ChatLog",
      "description": "Record of a interaction between user and system.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model", "system_command"] },
        "confidence": { "type": "number" },
        "mode": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "role", "timestamp"]
    }
  },
  "firestore": {
    "system/state": {
      "schema": "SystemState",
      "description": "The unique global state document."
    },
    "memories": {
      "schema": "Memory",
      "description": "Collection of knowledge fragments."
    },
    "chat_logs": {
      "schema": "ChatLog",
      "description": "Collection of conversation logs."
    }
  }
}
